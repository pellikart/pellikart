#!/usr/bin/env sh
# Block pushes that don't compile under tsc -b (what Vercel runs).
# `tsc --noEmit` is looser and misses errors that the deploy build catches —
# we got burned by 4+ deploys failing in CI over a single week of work
# (setCategoryFields dangling reference, missing getListingConfig import, etc.).
echo "→ Running npm run build before push…"
npm run build || {
  echo
  echo "✗ Build failed. Push blocked. Fix the errors above and try again."
  echo "  (To bypass in an emergency: git push --no-verify — but Vercel will still fail.)"
  exit 1
}
echo "✓ Build green — proceeding with push."
